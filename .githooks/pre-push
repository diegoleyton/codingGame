#!/bin/bash
set -e

UNITY="/Applications/Unity/Hub/Editor/6000.0.26f1/Unity.app/Contents/MacOS/Unity"
PROJECT_PATH="$(pwd)"
LOG_FILE="$PROJECT_PATH/Temp/unity-test-prepush.log"

run_tests () {
  PLATFORM=$1
  RESULTS_FILE="$PROJECT_PATH/Temp/unity-test-results-$PLATFORM.xml"

  echo "Running Unity $PLATFORM tests..."

  "$UNITY" \
    -batchmode \
    -quit \
    -projectPath "$PROJECT_PATH" \
    -runTests \
    -testPlatform "$PLATFORM" \
    -testResults "$RESULTS_FILE" \
    -logFile "$LOG_FILE"
}

run_tests EditMode
run_tests PlayMode

echo "All Unity tests passed."